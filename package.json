{
  "name": "openclips",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server/index.mjs",
    "build": "vite build && curl -fsSL https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o ./yt-dlp && chmod +x ./yt-dlp && echo 'yt-dlp installed:' $(./yt-dlp --version) || true",
    "preview": "NODE_ENV=production node server/index.mjs",
    "check": "npm run build",
    "cleanup": "node scripts/cleanup-old-sources.mjs",
    "cleanup:dry": "node scripts/cleanup-old-sources.mjs --dry-run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "express": "^5.2.1",
    "groq-sdk": "^1.1.2",
    "multer": "^2.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "vite": "^8.0.11"
  }
}
