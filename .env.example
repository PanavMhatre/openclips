GROQ_API_KEY=
GROQ_API_KEYS=
PORT=3000
OPENCLIPS_GROQ_CHAT_MODEL=llama-3.1-8b-instant
OPENCLIPS_GROQ_TRANSCRIBE_MODEL=whisper-large-v3
OPENCLIPS_KEEP_FULL_SOURCE=false
OPENCLIPS_BACKGROUND_MUSIC=true
OPENCLIPS_BACKGROUND_MUSIC_VOLUME=0.055
OPENCLIPS_DELETE_LOCAL_VIDEO_AFTER_CLOUD=true
BUFFER_API_KEY=
# Optional: comma-separated channel IDs (overrides include/exclude filters)
BUFFER_CHANNEL_IDS=
# Pod by Edit only — OpenClips will never post to clipvltdaily when these are set
BUFFER_CHANNEL_INCLUDE=podbyteedits,podbyte
BUFFER_CHANNEL_EXCLUDE=clipvltdaily,clipvlt
DISCORD_WEBHOOK_URL=
GITHUB_STORAGE_REPO=panavm12-jpg/storage
GITHUB_STORAGE_BRANCH=main
GITHUB_STORAGE_DIR=openclips
GITHUB_STORAGE_TOKEN=
GITHUB_STORAGE_MAX_BYTES=99614720
OPENCLIPS_PUBLIC_BASE_URL=
# Path to a Netscape-format cookies file exported from your browser (needed on cloud IPs)
# Export from Chrome/Firefox with the "Get cookies.txt LOCALLY" extension
# yt-dlp uses this to bypass YouTube bot detection on cloud environments
YT_DLP_COOKIES_FILE=
